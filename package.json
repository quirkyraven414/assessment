{
  "name": "iot-telemetry-system",
  "version": "1.0.0",
  "description": "Production-grade IoT Telemetry System with Kafka, PostgreSQL, Redis, OpenSearch",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev:api": "ts-node-dev --respawn --transpile-only src/api/index.ts",
    "dev:consumer": "ts-node-dev --respawn --transpile-only src/consumer/index.ts",
    "dev:websocket": "ts-node-dev --respawn --transpile-only src/websocket/index.ts",
    "start:api": "node dist/api/index.js",
    "start:consumer": "node dist/consumer/index.js",
    "start:websocket": "node dist/websocket/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "iot",
    "kafka",
    "timescaledb",
    "redis",
    "opensearch"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@opensearch-project/opensearch": "^2.12.0",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "kafkajs": "^2.2.4",
    "lodash": "^4.18.1",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
